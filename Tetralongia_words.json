  "grammar_rules": {
    "description": "Tetralongia grammar system based on periodic table groups",
    "noun_formation": "Group 14 of Periodic Table (C, Si, Ge, Sn, Pb) endings - '-ik' suffix",
    "verb_formation": "Group 17 of Periodic Table (F, Cl, Br, I) endings - '-af' or '-of' suffix",
    "adjective_formation": "Lithium (Li) endings - '-li' suffix",
    "adverb_formation": "Sodium (Na) endings - '-na' suffix",
    "connectors": "Transition metals (Co, Ni, Ti, Cu, Zn, Fe, I) - single letter or digraph",
    "questions": "Helium (He) prefix pattern - 'He...?' structure"
  },

  "periodic_table_mapping": {
    "H": "Hydrogen - Human origin - 'who' questions and basic structures",
    "He": "Helium - Light and fast - Questions, greetings, interrogatives",
    "Li": "Lithium - Reactive metal - Adjectives and descriptive words",
    "Na": "Sodium - Mobile alkali metal - Adverbs and manner",
    "C": "Carbon - Base of life - Nouns group 1 (basic elements)",
    "Si": "Silicon - Ordered structures - Nouns group 2 (constructed objects)",
    "F": "Fluorine - Highly reactive - Verbs (strong, immediate action)",
    "Cl": "Chlorine - Reactive halogens - Verbs (medium action)",
    "Fe": "Iron - Bonding and strength - Relative clauses and connections",
    "Co": "Cobalt - Coordination chemistry - 'And' / conjunction",
    "Cu": "Copper - Conductor of causality - 'Because' / causal connection",
    "I": "Iodine - Attractive bonds - 'Possession' and ownership"
  },

  "usage_notes": {
    "note_1": "Tetralongia is a systematic constructed language (conlang) designed to reflect chemical properties through linguistic patterns",
    "note_2": "Elemental symbols can be combined to form compound words with meanings derived from chemical reactions and element properties",
    "note_3": "The language serves both as a creative linguistic experiment and as a mnemonic tool for learning the periodic table",
    "note_4": "Each translation maintains the core Tetralongia word root while adapting pronunciation and structure to each language's phonological system",
    "note_5": "The grammar system is based on Group periodicity, creating logical associations between word categories and element families",
    "note_6": "Samoan and Hawaiian translations add Pacific Island perspectives to this global linguistic experiment",
    "note_7": "The complete vocabulary now covers 70 items across 30 major world languages plus sign language considerations"
  },

